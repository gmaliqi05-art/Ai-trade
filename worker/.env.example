# ── FastT worker — kopjoje si .env dhe plotëso ──
# MetaApi
METAAPI_TOKEN=your_metaapi_token
METAAPI_ACCOUNT_ID=your_account_id
METAAPI_REGION=new-york
FASTT_SYMBOL=XAUUSD+

# Supabase (për config + regjistrim trade-sh; përdor SERVICE ROLE key)
SUPABASE_URL=https://zwyuscgqacfpjafznybg.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
FASTT_USER_ID=your_user_uuid

# Strategjia (opsionale — truri tick-driven përdor prag të brendshëm ATR-shkallë; këto mjaftojnë)
FASTT_LOT=0.01
FASTT_CATASTROPHE_USD=2.0
FASTT_TICK_MS=250
FASTT_COOLDOWN_MS=20000
